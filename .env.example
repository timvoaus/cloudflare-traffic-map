# Optional values used by npm run setup
# Copy this file to .env and fill in values if you do not want to paste them during setup.

# Cloudflare account that contains your Zero Trust / Gateway logs
CF_ACCOUNT_ID=

# API token permission: Account -> Zero Trust -> Read
CF_API_TOKEN=

# Any long random string used to authorize manual /refresh calls
REFRESH_TOKEN=

# Optional existing D1 database UUID. Leave blank if setup should create one.
D1_DATABASE_ID=
